# ─────────────────────────────────────────────────────────────
#  Arogya AI — Vercel Production Environment Variables
#  Copy these keys into: Vercel → Project → Settings → Env Vars
#  DO NOT commit this file with real values.
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────

# Your deployed FastAPI backend URL (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=https://your-fastapi-backend.com

# JWT session signing secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace_with_64_char_hex_string

# PostgreSQL connection string (Supabase / Neon / Railway etc.)
POSTGRES_URL=postgresql://user:password@host:5432/dbname

# ── WHATSAPP ──────────────────────────────────────────────────

# WhatsApp number without + (used for wa.me links)
NEXT_PUBLIC_WHATSAPP_NUMBER=918274820374

# ── OPTIONAL ─────────────────────────────────────────────────

# MongoDB (only if frontend routes query MongoDB directly)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
# MONGODB_DB_NAME=arogya_ai_chat
